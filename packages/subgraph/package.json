{
  "name": "automated-vaults-subgraph",
  "private": true,
  "version": "0.0.1",
  "license": "GPL-3.0",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "codegen": "./node_modules/.bin/graph codegen -o types",
    "build": "./node_modules/.bin/graph build",
    "build:base": "NETWORK=base ./scripts/build.sh",
    "build:mainnet": "NETWORK=mainnet ./scripts/build.sh",
    "deploy": "./scripts/deploy.sh",
    "test": "echo skip"
  },
  "dependencies": {
    "@chainlink/contracts": "^0.2.1"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.74.1",
    "@graphprotocol/graph-ts": "^0.31.0",
    "@typescript-eslint/eslint-plugin": "^4.1.1",
    "@typescript-eslint/parser": "^4.1.1",
    "eslint": "^7.9.0",
    "eslint-config-mimic": "^0.0.2",
    "eslint-plugin-array-func": "^5.1.0",
    "ethers": "~5.6.0",
    "js-yaml": "^4.1.0",
    "ts-node": "^10.9.1",
    "typescript": "~4.3.4"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "project": "./tsconfig.json"
    },
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "ignorePatterns": [
      "build",
      "types",
      "generated"
    ]
  }
}
